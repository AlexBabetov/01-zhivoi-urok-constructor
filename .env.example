# .env.example — 01-zhivoi-urok-constructor
# Все переменные задаются в Netlify → Site settings → Environment variables
# НЕ коммитить .env файлы с реальными значениями в репозиторий

# Claude API (Anthropic Console)
# Используется: netlify/edge-functions/generate-lesson.js
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub (для хранения уроков в репозитории)
# Используется: netlify/functions/save-lesson.js
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=AlexBabetov/01-zhivoi-urok-constructor

# Supabase (аутентификация + аналитика)
# Используется: src/AuthGate.jsx (frontend)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase URL для серверных функций (без REACT_APP_ префикса!)
# Используется: netlify/functions/save-lesson.js (логирование событий)
# ⚠️ Отличается от REACT_APP_SUPABASE_URL — нужна отдельно в Netlify env vars
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role (только для серверных функций, не в frontend!)
# Используется: netlify/functions/list-pending-users.js, update-user-status.js, save-lesson.js
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Resend (email-уведомления с info@koriphey.ru)
# Используется: netlify/functions/notify-admin.js, update-user-status.js
RESEND_API_KEY=your_resend_api_key_here

# Email администратора (получает уведомления о новых регистрациях)
# Используется: netlify/functions/notify-admin.js
ADMIN_EMAIL=babetov_aa@koriphey.ru
